{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@medflow/shared": ["packages/shared/src"],
      "@medflow/shared/*": ["packages/shared/src/*"],
      "@medflow/ui": ["packages/ui/src"],
      "@medflow/ui/*": ["packages/ui/src/*"]
    }
  }
}
