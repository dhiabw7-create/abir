generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  SUPER_ADMIN
  DOCTOR
  SECRETARY
}

enum AppointmentStatus {
  SCHEDULED
  ARRIVED
  IN_WAITING
  IN_CONSULTATION
  DONE
  CANCELED
  NO_SHOW
}

enum WaitingRoomStatus {
  WAITING
  CALLED
  PAUSED
  DONE
  SKIPPED
}

enum BordereauStatus {
  DRAFT
  EXPORTED
  ARCHIVED
  CORRECTIVE
}

enum CNAMRecordStatus {
  PENDING
  IN_BORDEREAU
  EXPORTED
  PAID
  REJECTED
}

enum DocumentTemplateType {
  MEDICAL_CERTIFICATE
  SICK_LEAVE
  SCHOOL_CERTIFICATE
  FITNESS_CERTIFICATE
  REFERRAL
  IMAGING_REQUEST
  LAB_REQUEST
  INVOICE
  RECEIPT
  CNAM_GENERIC
}

enum DocumentLanguage {
  FR
  AR
  BILINGUAL
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum ReminderChannel {
  SMS
  EMAIL
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELED
}

model Plan {
  id           String   @id @default(uuid())
  name         String
  code         String   @unique
  monthlyPrice Decimal  @db.Decimal(10, 2)
  yearlyPrice  Decimal  @db.Decimal(10, 2)
  maxDoctors   Int
  maxStaff     Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenants Tenant[]
}

model Tenant {
  id                 String                  @id @default(uuid())
  name               String
  slug               String                  @unique
  timezone           String                  @default("Africa/Tunis")
  locale             String                  @default("fr")
  planId             String?
  isActive           Boolean                 @default(true)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  plan               Plan?                   @relation(fields: [planId], references: [id])
  users              User[]
  roles              Role[]
  permissions        Permission[]
  rolePermissions    RolePermission[]
  userPermissions    UserPermission[]
  refreshTokens      RefreshToken[]
  patients           Patient[]
  patientInsurances  PatientInsurance[]
  medicalHistories   MedicalHistory[]
  allergies          Allergy[]
  chronicTreatments  ChronicTreatment[]
  appointments       Appointment[]
  waitingRoomEntries WaitingRoomEntry[]
  diagnoses          Diagnosis[]
  consultations      Consultation[]
  vitalSigns         VitalSigns[]
  medicationCatalogs MedicationCatalog[]
  medicationItems    MedicationItem[]
  medicationPrices   MedicationPrice[]
  medicationInteractions MedicationInteraction[]
  catalogImportLogs  CatalogImportLog[]
  prescriptions      Prescription[]
  prescriptionLines  PrescriptionLine[]
  documentTemplates  DocumentTemplate[]
  generatedDocuments GeneratedDocument[]
  cnamRecords        CNAMConsultationRecord[]
  bordereaux         Bordereau[]
  bordereauItems     BordereauItem[]
  bordereauExports   BordereauExport[]
  bordereauRejections BordereauRejection[]
  fileAttachments    FileAttachment[]
  payments           Payment[]
  invoices           Invoice[]
  auditLogs          AuditLog[]
  backupLogs         BackupLog[]
  notificationLogs   NotificationLog[]
  reminderJobs       ReminderJob[]
  settings           TenantSetting?
  workingHours       WorkingHour[]
}

model Role {
  id          String   @id @default(uuid())
  tenantId    String
  name        RoleName
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users           User[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Permission {
  id          String   @id @default(uuid())
  tenantId    String
  key         String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@unique([tenantId, key])
  @@index([tenantId])
}

model RolePermission {
  id           String   @id @default(uuid())
  tenantId     String
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([tenantId, roleId, permissionId])
  @@index([tenantId])
}

model UserPermission {
  id           String   @id @default(uuid())
  tenantId     String
  userId       String
  permissionId String
  allowed      Boolean  @default(true)
  createdAt    DateTime @default(now())

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, permissionId])
  @@index([tenantId])
}

model User {
  id            String     @id @default(uuid())
  tenantId      String
  roleId        String
  firstName     String
  lastName      String
  email         String     @unique
  passwordHash  String
  phone         String?
  isActive      Boolean    @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  tenant                Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role                  Role                  @relation(fields: [roleId], references: [id], onDelete: Restrict)
  userPermissions       UserPermission[]
  refreshTokens         RefreshToken[]
  createdAppointments   Appointment[]         @relation("DoctorAppointments")
  waitingRoomHandled    WaitingRoomEntry[]    @relation("WaitingHandledBy")
  consultations         Consultation[]        @relation("DoctorConsultations")
  createdPrescriptions  Prescription[]        @relation("DoctorPrescriptions")
  generatedDocuments    GeneratedDocument[]   @relation("DoctorGeneratedDocuments")
  uploadedFiles         FileAttachment[]      @relation("UploadedBy")
  createdInvoices       Invoice[]             @relation("InvoiceCreatedBy")
  reminderJobs          ReminderJob[]         @relation("ReminderCreatedBy")
  backupLogs            BackupLog[]           @relation("BackupTriggeredBy")
  auditEvents           AuditLog[]            @relation("AuditActor")
  importedCatalogs      MedicationCatalog[]   @relation("CatalogImportedBy")
  catalogImportLogs     CatalogImportLog[]    @relation("CatalogImportBy")
  bordereaux            Bordereau[]           @relation("BordereauDoctor")
  notificationLogs      NotificationLog[]     @relation("NotificationUser")
  workingHours          WorkingHour[]

  @@index([tenantId])
  @@index([roleId])
}

model RefreshToken {
  id           String   @id @default(uuid())
  tenantId     String
  userId       String
  tokenHash    String
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  actorUserId String?
  action     String
  entity     String
  entityId   String
  beforeData Json?
  afterData  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor  User?  @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([actorUserId])
  @@index([entity, entityId])
}

model BackupLog {
  id              String   @id @default(uuid())
  tenantId        String
  triggeredByUserId String?
  status          String
  filePath        String?
  message         String?
  createdAt       DateTime @default(now())

  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  triggeredBy User?  @relation("BackupTriggeredBy", fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
}

model Patient {
  id                    String            @id @default(uuid())
  tenantId              String
  ficheNumber           String
  cnamNumber            String?
  nationalId            String?
  firstName             String
  lastName              String
  dateOfBirth           DateTime
  phone                 String
  address               String?
  gender                String?
  insuranceProvider     String?
  insurancePolicyNumber String?
  lastVisitAt           DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  tenant            Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  insurance         PatientInsurance?
  medicalHistory    MedicalHistory?
  allergies         Allergy[]
  chronicTreatments ChronicTreatment[]
  appointments      Appointment[]
  waitingRoomEntries WaitingRoomEntry[]
  consultations     Consultation[]
  prescriptions     Prescription[]
  generatedDocs     GeneratedDocument[]
  cnamRecords       CNAMConsultationRecord[]
  files             FileAttachment[]
  payments          Payment[]
  invoices          Invoice[]
  reminderJobs      ReminderJob[]

  @@unique([tenantId, ficheNumber])
  @@index([tenantId])
  @@index([lastName, firstName])
  @@index([cnamNumber])
  @@index([phone])
}

model PatientInsurance {
  id            String   @id @default(uuid())
  tenantId      String
  patientId     String   @unique
  cnamCardType  String?
  cnamRegime    String?
  cnamNumber    String?
  reimbursement String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model MedicalHistory {
  id         String   @id @default(uuid())
  tenantId   String
  patientId  String   @unique
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Allergy {
  id         String   @id @default(uuid())
  tenantId   String
  patientId  String
  name       String
  severity   String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([patientId])
}

model ChronicTreatment {
  id         String   @id @default(uuid())
  tenantId   String
  patientId  String
  label      String
  dosage     String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([patientId])
}

model Appointment {
  id         String            @id @default(uuid())
  tenantId   String
  patientId  String
  doctorId   String
  startAt    DateTime
  endAt      DateTime
  status     AppointmentStatus @default(SCHEDULED)
  reason     String?
  notes      String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient            Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor             User                @relation("DoctorAppointments", fields: [doctorId], references: [id], onDelete: Restrict)
  waitingRoomEntries WaitingRoomEntry[]
  consultations      Consultation[]

  @@index([tenantId])
  @@index([doctorId, startAt])
  @@index([patientId, startAt])
}

model WaitingRoomEntry {
  id             String            @id @default(uuid())
  tenantId       String
  appointmentId  String?
  patientId      String
  handledByUserId String?
  status         WaitingRoomStatus @default(WAITING)
  isUrgent       Boolean           @default(false)
  arrivalTime    DateTime
  calledAt       DateTime?
  completedAt    DateTime?
  priorityScore  Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  handledBy   User?        @relation("WaitingHandledBy", fields: [handledByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([status])
  @@index([arrivalTime])
}

model Diagnosis {
  id         String   @id @default(uuid())
  tenantId   String
  code       String
  label      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  consultations Consultation[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Consultation {
  id                String   @id @default(uuid())
  tenantId          String
  patientId         String
  doctorId          String
  appointmentId     String?
  diagnosisId       String?
  symptoms          String
  notes             String?
  doctorPrivateNote String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant       Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient      Patient                 @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor       User                    @relation("DoctorConsultations", fields: [doctorId], references: [id], onDelete: Restrict)
  appointment  Appointment?            @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  diagnosis    Diagnosis?              @relation(fields: [diagnosisId], references: [id], onDelete: SetNull)
  vitalSigns   VitalSigns?
  prescriptions Prescription[]
  generatedDocs GeneratedDocument[]
  cnamRecord   CNAMConsultationRecord?
  files        FileAttachment[]
  payments     Payment[]

  @@index([tenantId])
  @@index([patientId, createdAt])
  @@index([doctorId, createdAt])
}

model VitalSigns {
  id             String   @id @default(uuid())
  tenantId       String
  consultationId String   @unique
  bloodPressure  String?
  pulseBpm       Int?
  temperatureC   Float?
  weightKg       Float?
  heightCm       Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  consultation Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model MedicationCatalog {
  id             String   @id @default(uuid())
  tenantId       String
  importedByUserId String?
  source         String
  catalogVersion String
  sourceMetadata Json?
  isDemo         Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  importedBy  User?             @relation("CatalogImportedBy", fields: [importedByUserId], references: [id], onDelete: SetNull)
  items       MedicationItem[]
  importLogs  CatalogImportLog[]

  @@unique([tenantId, source, catalogVersion])
  @@index([tenantId])
}

model MedicationItem {
  id             String   @id @default(uuid())
  tenantId       String
  catalogId      String
  code           String
  brandName      String
  dciName        String?
  dosageForm     String?
  strength       String?
  familyClass    String?
  reimbursable   Boolean  @default(false)
  cnamCode       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant         Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  catalog        MedicationCatalog       @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  prices         MedicationPrice[]
  interactionsA  MedicationInteraction[] @relation("InteractionItemA")
  interactionsB  MedicationInteraction[] @relation("InteractionItemB")
  prescriptionLines PrescriptionLine[]

  @@unique([tenantId, code, catalogId])
  @@index([tenantId])
  @@index([brandName])
  @@index([dciName])
}

model MedicationPrice {
  id             String   @id @default(uuid())
  tenantId       String
  medicationItemId String
  unitPrice      Decimal  @db.Decimal(10, 3)
  reimbursementInfo String?
  startsAt       DateTime @default(now())
  endsAt         DateTime?
  createdAt      DateTime @default(now())

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  medicationItem MedicationItem @relation(fields: [medicationItemId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([medicationItemId])
}

model MedicationInteraction {
  id             String   @id @default(uuid())
  tenantId       String
  medicationAId  String
  medicationBId  String
  severity       String
  description    String
  createdAt      DateTime @default(now())

  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  medicationA MedicationItem @relation("InteractionItemA", fields: [medicationAId], references: [id], onDelete: Cascade)
  medicationB MedicationItem @relation("InteractionItemB", fields: [medicationBId], references: [id], onDelete: Cascade)

  @@unique([tenantId, medicationAId, medicationBId])
  @@index([tenantId])
}

model CatalogImportLog {
  id             String   @id @default(uuid())
  tenantId       String
  catalogId      String
  importedByUserId String?
  fileName       String
  status         String
  rowCount       Int
  successCount   Int
  failedCount    Int
  metadata       Json?
  createdAt      DateTime @default(now())

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  catalog     MedicationCatalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  importedBy  User?             @relation("CatalogImportBy", fields: [importedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
}

model Prescription {
  id             String   @id @default(uuid())
  tenantId       String
  patientId      String
  doctorId       String
  consultationId String?
  estimatedTotal Decimal  @db.Decimal(10, 3)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor       User          @relation("DoctorPrescriptions", fields: [doctorId], references: [id], onDelete: Restrict)
  consultation Consultation? @relation(fields: [consultationId], references: [id], onDelete: SetNull)
  lines        PrescriptionLine[]

  @@index([tenantId])
  @@index([patientId, createdAt])
}

model PrescriptionLine {
  id               String   @id @default(uuid())
  tenantId         String
  prescriptionId   String
  medicationItemId String?
  medicationLabel  String
  dose             String
  frequency        String
  durationDays     Int
  instructions     String?
  quantity         Int
  unitPrice        Decimal? @db.Decimal(10, 3)
  lineTotal        Decimal? @db.Decimal(10, 3)
  createdAt        DateTime @default(now())

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prescription   Prescription    @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medicationItem MedicationItem? @relation(fields: [medicationItemId], references: [id], onDelete: SetNull)

  @@index([tenantId])
}

model DocumentTemplate {
  id              String               @id @default(uuid())
  tenantId        String
  name            String
  type            DocumentTemplateType
  language        DocumentLanguage
  body            String               @db.Text
  footer          String?
  isGlobalLibrary Boolean              @default(false)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  generated  GeneratedDocument[]

  @@index([tenantId])
}

model GeneratedDocument {
  id             String   @id @default(uuid())
  tenantId       String
  patientId      String
  doctorId       String
  templateId     String
  consultationId String?
  title          String
  payload        Json
  filePath       String
  createdAt      DateTime @default(now())

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient      Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor       User           @relation("DoctorGeneratedDocuments", fields: [doctorId], references: [id], onDelete: Restrict)
  template     DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  consultation Consultation?  @relation(fields: [consultationId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([patientId, createdAt])
}

model CNAMConsultationRecord {
  id             String           @id @default(uuid())
  tenantId       String
  patientId      String
  consultationId String           @unique
  cnamCode       String
  eligible       Boolean          @default(true)
  amount         Decimal          @db.Decimal(10, 3)
  status         CNAMRecordStatus @default(PENDING)
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  consultation Consultation  @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  bordereauItems BordereauItem[]

  @@index([tenantId])
  @@index([status])
}

model Bordereau {
  id           String         @id @default(uuid())
  tenantId     String
  doctorId     String
  reference    String
  periodStart  DateTime
  periodEnd    DateTime
  status       BordereauStatus @default(DRAFT)
  totalAmount  Decimal        @db.Decimal(12, 3)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  doctor   User             @relation("BordereauDoctor", fields: [doctorId], references: [id], onDelete: Restrict)
  items    BordereauItem[]
  exports  BordereauExport[]

  @@unique([tenantId, reference])
  @@index([tenantId])
}

model BordereauItem {
  id             String   @id @default(uuid())
  tenantId       String
  bordereauId    String
  cnamRecordId   String
  amount         Decimal  @db.Decimal(10, 3)
  createdAt      DateTime @default(now())

  tenant     Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bordereau  Bordereau             @relation(fields: [bordereauId], references: [id], onDelete: Cascade)
  cnamRecord CNAMConsultationRecord @relation(fields: [cnamRecordId], references: [id], onDelete: Cascade)
  rejections BordereauRejection[]

  @@unique([tenantId, bordereauId, cnamRecordId])
  @@index([tenantId])
}

model BordereauExport {
  id           String   @id @default(uuid())
  tenantId     String
  bordereauId  String
  format       String
  filePath     String
  checksum     String?
  createdAt    DateTime @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bordereau Bordereau @relation(fields: [bordereauId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model BordereauRejection {
  id               String   @id @default(uuid())
  tenantId         String
  bordereauItemId  String
  reason           String
  resolved         Boolean  @default(false)
  correctiveNote   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bordereauItem BordereauItem @relation(fields: [bordereauItemId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model FileAttachment {
  id             String   @id @default(uuid())
  tenantId       String
  patientId      String?
  consultationId String?
  uploadedByUserId String
  category       String
  fileName       String
  mimeType       String
  fileSize       Int
  storagePath    String
  isMedical      Boolean  @default(false)
  createdAt      DateTime @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient      Patient?      @relation(fields: [patientId], references: [id], onDelete: SetNull)
  consultation Consultation? @relation(fields: [consultationId], references: [id], onDelete: SetNull)
  uploadedBy   User          @relation("UploadedBy", fields: [uploadedByUserId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([patientId])
}

model Invoice {
  id              String   @id @default(uuid())
  tenantId        String
  patientId       String
  createdByUserId String
  invoiceNumber   String
  amount          Decimal  @db.Decimal(10, 3)
  issuedAt        DateTime @default(now())
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  createdBy User     @relation("InvoiceCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  payments  Payment[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
}

model Payment {
  id             String      @id @default(uuid())
  tenantId       String
  patientId      String
  consultationId String?
  invoiceId      String?
  amount         Decimal     @db.Decimal(10, 3)
  method         PaymentMethod
  paidAt         DateTime
  createdAt      DateTime    @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  consultation Consultation? @relation(fields: [consultationId], references: [id], onDelete: SetNull)
  invoice      Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([paidAt])
}

model NotificationLog {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String?
  title      String
  message    String
  channel    String
  status     String
  metadata   Json?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation("NotificationUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
}

model ReminderJob {
  id             String         @id @default(uuid())
  tenantId       String
  appointmentId  String?
  patientId      String?
  createdByUserId String?
  channel        ReminderChannel
  payload        Json
  scheduledFor   DateTime
  status         ReminderStatus @default(PENDING)
  attempts       Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient   Patient?    @relation(fields: [patientId], references: [id], onDelete: SetNull)
  createdBy User?       @relation("ReminderCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([scheduledFor])
}

model TenantSetting {
  id              String   @id @default(uuid())
  tenantId        String   @unique
  clinicName      String
  clinicAddress   String?
  clinicPhone     String?
  logoPath        String?
  stampPath       String?
  signaturePath   String?
  documentFooter  String?
  theme           String   @default("system")
  language        String   @default("fr")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model WorkingHour {
  id         String   @id @default(uuid())
  tenantId   String
  doctorId   String
  dayOfWeek  Int
  startTime  String
  endTime    String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  doctor User   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([tenantId, doctorId, dayOfWeek, startTime, endTime])
  @@index([tenantId])
}
