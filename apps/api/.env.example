NODE_ENV=development
PORT=3000
WEB_ORIGIN=http://localhost:5173
DATABASE_URL=mysql://medflow:medflow@localhost:3306/medflow
JWT_ACCESS_SECRET=replace_me_access_secret
JWT_REFRESH_SECRET=replace_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
COOKIE_SECURE=false
# Local development without Redis: keep true.
# Set to false when Redis is available (Docker or local service).
REDIS_DISABLED=true
REDIS_URL=redis://localhost:6379
STORAGE_MODE=local
STORAGE_LOCAL_PATH=./uploads
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=medflow
