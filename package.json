{
  "name": "medflow-saas",
  "private": true,
  "version": "1.0.0",
  "description": "Multi-tenant clinic management SaaS",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:api dev:web",
    "dev:web": "npm run dev -w @medflow/web",
    "dev:api": "npm run start:dev -w @medflow/api",
    "build": "npm-run-all build:shared build:ui build:api build:web",
    "build:shared": "npm run build -w @medflow/shared",
    "build:ui": "npm run build -w @medflow/ui",
    "build:api": "npm run build -w @medflow/api",
    "build:web": "npm run build -w @medflow/web",
    "lint": "npm-run-all lint:api lint:web",
    "lint:api": "npm run lint -w @medflow/api",
    "lint:web": "npm run lint -w @medflow/web",
    "test": "npm-run-all test:api test:web",
    "test:api": "npm run test -w @medflow/api",
    "test:web": "npm run test -w @medflow/web"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
